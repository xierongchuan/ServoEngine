# Trading mode (demo или real)
MODE=demo
# Exchange (bingx or capital)
EXCHANGE=bingx

# AI API
DEEPSEEK_API_KEY=your_deepseek_api_key
SILICONFLOW_API_KEY=sk-your-siliconflow-key-here
OPENROUTER_API_KEY=sk-your-siliconflow-key-here

# BingX API credentials
BINGX_API_KEY=your_api_key
BINGX_SECRET_KEY=your_secret_key

# Capital.com API credentials (Демо аккаунт)
CAP_API_USERNAME=your_demo_username
CAP_API_PASSWORD=your_demo_password
CAP_API_KEY=your_api_key_from_capital_settings

# News processing
ENABLE_NEWS=true
