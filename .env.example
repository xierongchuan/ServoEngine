# Конфигурационный файл для торговой системы OpenProducer
# Скопируйте этот файл как .env и заполните своими данными

# ==============================================================================
# НАСТРОЙКИ РЕЖИМА
# ==============================================================================
# "demo" для тестов, "real" для реальных денег
MODE=demo

# ==============================================================================
# DEEPSEEK API
# ==============================================================================
# Получите API ключ на https://platform.deepseek.com/
# ОБЯЗАТЕЛЬНО: без этого ключа система не сможет генерировать прогнозы
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ==============================================================================
# CAPITAL.COM (демо счет)
# ==============================================================================
# Учетные данные от вашего демо аккаунта на capital.com
# ОБЯЗАТЕЛЬНО: без них система не сможет торговать
DEMO_USERNAME=your_demo_email@example.com
DEMO_PASSWORD=your_demo_password_here

# API ключ Capital.com из Settings > API Integrations
# ОБЯЗАТЕЛЬНО: без него система не сможет авторизоваться в Capital.com API
# Как получить:
# 1. Войдите в аккаунт Capital.com
# 2. Settings > API Integrations
# 3. Generate API key
# 4. Сохраните ключ (он показывается только один раз!)
CAP_API_KEY=your_capital_api_key_here

# ==============================================================================
# ПРИМЕЧАНИЯ
# ==============================================================================
# 1. НЕ коммитьте файл .env в git! Добавьте его в .gitignore
# 2. В продакшене используйте переменные окружения вместо .env
# 3. Все значения указывайте без кавычек
# 4. Строки с # являются комментариями и игнорируются
