# =============================================================================
# OpenProducer Trading System - Environment Variables
# =============================================================================
# Копируйте этот файл в .env и заполните своими значениями

# -----------------------------------------------------------------------------
# CAPITAL.COM API (Обязательно для торговли)
# -----------------------------------------------------------------------------
# Получите API ключ: Settings → API Integrations
CAP_API_KEY=your_capital_api_key

# Логин и пароль от Capital.com (используется для демо и реального режима)
CAP_API_USERNAME=your_capital_username
CAP_API_PASSWORD=your_capital_password

# -----------------------------------------------------------------------------
# DEEPSEEK AI (Обязательно для торговых сигналов)
# -----------------------------------------------------------------------------
# Получите ключ: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key

# -----------------------------------------------------------------------------
# NEWS API PROVIDERS (Опционально для реальных новостей)
# -----------------------------------------------------------------------------
# 1. NewsAPI.org - 1000 запросов/день бесплатно
# Регистрация: https://newsapi.org
NEWSAPI_KEY=your_newsapi_key

# 2. Alpha Vantage - 500 запросов/день бесплатно (Рекомендуется для торговли!)
# Регистрация: https://www.alphavantage.co
ALPHAVANTAGE_KEY=your_alphavantage_key

# 3. Finnhub - 60 запросов/минуту бесплатно
# Регистрация: https://finnhub.io
FINNHUB_KEY=your_finnhub_key

# -----------------------------------------------------------------------------
# SYSTEM CONFIGURATION
# -----------------------------------------------------------------------------
# Режим работы: "demo" для тестирования, "real" для реальной торговли
MODE=demo

# -----------------------------------------------------------------------------
# ИСПОЛЬЗОВАНИЕ РЕАЛЬНЫХ НОВОСТЕЙ
# -----------------------------------------------------------------------------
# Для активации реальных новостей:
# 1. Получите API ключ (рекомендуется Alpha Vantage)
# 2. Раскомментируйте строку выше
# 3. Настройте в config.py:
#    NEWS_SETTINGS["use_real_news"] = True
#    NEWS_SETTINGS["provider"] = "alphavantage"
