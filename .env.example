# Trading mode (demo или real)
MODE=demo
# Exchange bingx
EXCHANGE=bingx

# AI API (OpenRouter)
OPENROUTER_API_KEY=sk-your-openrouter-key-here

# BingX API credentials
BINGX_API_KEY=your_api_key
BINGX_SECRET_KEY=your_secret_key

# News processing
ENABLE_NEWS=false

# Telegram Panel
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
# Список Telegram user ID с доступом к панели и боту (через запятую)
TELEGRAM_ALLOWED_IDS=
# HTTPS URL для Mini App (оставить пустым для ngrok, задать для prod)
TELEGRAM_PANEL_URL=
PANEL_PORT=8080

# VPS Tunnel (for Telegram Mini App HTTPS)
# Set VPS_HOST to enable automatic SSH tunnel to your server
VPS_HOST=
VPS_USER=root
VPS_PORT=9080
