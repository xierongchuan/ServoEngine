{
  "_description": "MACDX 5m: быстрые кроссоверы с двухсвечным подтверждением",
  "_version": "1.0.0",
  "_inherits": "default",
  "_strategy": "MACDX",
  "preset": {
    "timeframe": "5m",
    "chart_period": "3D",
    "plotter_period": "3D",
    "history_candles": 864,
    "loop_interval": 60,
    "position_check_interval": 15,
    "sl_multiplier": 1.3,
    "tp_multiplier": 2.8,
    "leverage": 5,
    "cooldown_after_close_hours": 0.75
  },
  "signal_rules": {
    "min_atr_percent": 0.1,
    "bb_width_threshold": 0.55,
    "require_2_candle_confirmation": true
  },
  "exit_rules": {"emergency": {"max_hold_candles": 72}}
}
