{
  "_description": "Backtest engine configuration",
  "_version": "1.0.0",

  "capital": {
    "initial_balance": 1000.0,
    "mode": "isolated",
    "_mode_options": ["isolated", "full_capital"],
    "_mode_description": "isolated = fixed initial_balance; full_capital = use entire balance for position sizing"
  },

  "commission": {
    "maker_rate": 0.0002,
    "taker_rate": 0.0005,
    "use_exchange_rates": true,
    "_description": "Commission rates as decimals (0.0002 = 0.02%)"
  },

  "execution": {
    "slippage_bps": 2.0,
    "_description": "Adverse market-order slippage in basis points per fill"
  },

  "defaults": {
    "sl_percent": 10.0,
    "tp_percent": 10.0,
    "_description": "Default SL/TP percentages when not provided by strategy signal"
  },

  "exit_rules": {
    "macd_reversal": {
      "enabled": false,
      "profit_threshold": 0.005,
      "loss_threshold": -0.01
    },
    "rsi_extreme": {
      "enabled": false,
      "long_exit_above": 80,
      "short_exit_below": 20
    }
  },

  "report": {
    "save_to_file": true,
    "output_path": "data/backtest_result.json"
  }
}
