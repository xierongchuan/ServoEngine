{
  "_description": "Core trading parameters - changed occasionally",
  "_version": "1.0.0",

  "position": {
    "size_percent": 100,
    "min_trade_amount_usdt": 10
  },

  "risk": {
    "min_confidence_threshold": 0.55,
    "min_risk_reward_ratio": 1.2,
    "min_partial_close_pnl": 0.5,
    "take_profit_percent": 2.5,
    "stop_loss_percent": 1
  },

  "features": {
    "enable_news": false,
    "enable_advanced_analysis": true,
    "enable_parallel_mode": true,
    "enable_ai_skip_on_rsi": false,
    "enable_low_volume_filter": false,
    "aggressive_mode": false,
    "enable_immediate_reentry_after_exit": false
  },

  "aggressive_settings": {
    "rsi_buy_cond": 70,
    "rsi_buy_forbidden": 85,
    "rsi_sell_cond": 30,
    "rsi_sell_forbidden": 15,
    "min_risk_reward_ratio": 1.3,
    "min_confidence": 0.55
  },

  "ai_thresholds": {
    "rsi_oversold": 30,
    "rsi_overbought": 70,
    "min_positive_news": 3,
    "min_negative_news": 3,
    "strong_signal_confidence": 0.8,
    "sma_period": 20,
    "rsi_period": 14,
    "rsi_neutral_min": 48,
    "rsi_neutral_max": 52,
    "rsi_buy_entry_max": 65,
    "rsi_sell_entry_min": 35
  },

  "smart_sampling": {
    "enabled": true,
    "recent_candles": 40,
    "history_step": 1
  },

  "regime": {
    "enabled": true,
    "lookback_candles": 10,
    "ema_spread_thresholds": {
      "no_trend": 0.15,
      "weak": 0.5,
      "strong": 1.5
    },
    "volatility_percentile_window": 100,
    "params": {
      "TRENDING": {
        "min_score": 4,
        "sl_multiplier": 1.5,
        "tp_multiplier": 3.5,
        "position_size_factor": 1.2,
        "min_risk_reward_ratio": 1.2
      },
      "RANGING": {
        "min_score": 5,
        "sl_multiplier": 1.5,
        "tp_multiplier": 5,
        "position_size_factor": 0.8,
        "min_risk_reward_ratio": 0.8
      },
      "VOLATILE": {
        "min_score": 5,
        "sl_multiplier": 2,
        "tp_multiplier": 3.5,
        "position_size_factor": 0.6,
        "min_risk_reward_ratio": 1.0
      },
      "TRANSITIONAL": {
        "min_score": 5,
        "sl_multiplier": 2,
        "tp_multiplier": 3,
        "position_size_factor": 0.7,
        "min_risk_reward_ratio": 1.0
      }
    }
  },

  "dynamic_sizing": {
    "enabled": true,
    "min_size_pct": 3,
    "max_size_pct": 20,
    "quality_weight": 0.7,
    "quality_base": 0.5,
    "hot_streak_factor": 1.1,
    "cold_streak_factor": 0.5,
    "cold_streak_threshold": 0.3,
    "hot_streak_threshold": 0.6,
    "min_trades_for_streak": 5
  },

  "performance_tracking": {
    "enabled": true,
    "min_trades_for_analysis": 10,
    "win_rate_floor": 0.3
  },

  "momentum": {
    "enabled": true,
    "max_candles_in_prompt": 200,
    "momentum_entry_enabled": true,
    "momentum_consecutive_candles": 3
  }
}
