{
  "_description": "HYBRID - 5m swing with deterministic signals + AI confirmation",
  "_version": "1.0.0",

  "preset": {
    "timeframe": "5m",
    "chart_period": "1D",
    "plotter_period": "6h",
    "loop_interval": 60,
    "position_check_interval": 15,
    "atr_sl_mult": 1.5,
    "atr_tp_mult": 3,
    "leverage": 10
  },

  "signal_rules": {
    "trend_alignment_required": false,
    "min_volume_ratio": 0.15,
    "min_atr_ratio": 0.2,
    "min_score_for_signal": 4,
    "tier1_required": true,
    "conflict_friction_threshold": 4,
    "macd_exit_pnl_threshold": -1.5,

    "rsi_long_max": 48,
    "rsi_long_min": 20,
    "rsi_short_max": 80,
    "rsi_short_min": 52,
    "sr_proximity_pct": 3,

    "weights": {
      "ema_cross": 2,
      "rsi_zone": 2,
      "sr": 2,
      "volume": 1,
      "momentum": 1,
      "macd": 1,
      "bb": 1
    }
  },

  "ai_filter": {
    "enabled": true,
    "can_generate_signals": false,
    "min_confidence_to_approve": 0.55,
    "auto_approve_quality": 0.7,
    "invoke_on_borderline": true
  },

  "interaction_rules": {
    "ema_macd_confluence_bonus": 1,
    "reversal_confluence_bonus": 2,
    "momentum_burst_bonus": 1,
    "rsi_divergence_penalty": -2
  }
}
