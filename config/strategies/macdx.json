{
  "_description": "MACDX - MACD crossover strategy with 3-5 confirmations",
  "_version": "2.0.0",

  "preset": {
    "timeframe": "15m",
    "chart_period": "1D",
    "plotter_period": "1D",
    "loop_interval": 60,
    "position_check_interval": 15,
    "atr_sl_mult": 4.0,
    "atr_tp_mult": 7.0,
    "leverage": 9,
    "cooldown_after_close_hours": 0.5
  },

  "signal_rules": {
    "macd_cross_weight": 3,
    "rsi_zone_weight": 1,
    "ema_alignment_weight": 2,
    "strengthening_trend_weight": 3,
    "not_sideways_weight": 2,
    "no_exhaustion_weight": 1,
    "volume_weight": 2,
    "min_score_for_signal": 4,

    "enable_strengthening_trend_entry": false,
    "strengthening_trend_min_candles": 2,

    "min_volume_ratio": 0.79,
    "ignore_volume_on_strong_trend": false,

    "min_atr_ratio": 0.003,
    "rsi_long_max": 95,
    "rsi_long_min": 30,
    "rsi_short_max": 75,
    "rsi_short_min": 35,
    "bb_width_threshold": 0.5,
    "adx_threshold": 25,
    "sideways_block_signals": true,
    "consecutive_red_filter": true,
    "min_consecutive_for_block": 3,
    "enable_counter_trend_filter": true,
    "counter_trend_ema_threshold": 1.0,
    "enable_volume_filter": true,
    "volume_confirm_threshold": 0.7,
    "enable_risk_validation": false,
    "min_risk_reward_ratio": 1.2,
    "require_2_candle_confirmation": false
  },

  "exit_rules": {
    "macd_weakening": {
      "enabled": false,
      "threshold": 0.5,
      "min_candles_after_peak": 6,
      "min_candles_in_trade": 6,
      "min_profit_pct": 1.0,
      "adx_override": 45,
      "confirmation_candles": 3,
      "trend_strength_min": 0.7
    },
    "trailing_profit": {
      "enabled": false,
      "activation_pnl": 1.3,
      "drawdown_levels": {
        "high_profit": { "threshold": 8.0, "max_drawdown": 0.4 },
        "medium_profit": { "threshold": 5.0, "max_drawdown": 0.5 },
        "low_profit": { "threshold": 3.0, "max_drawdown": 0.6 }
      },
      "hysteresis_buffer": 0.35
    },
    "impulse_candle": {
      "enabled": true,
      "body_atr_multiplier": 2.0,
      "min_profit_pct": 1.9,
      "volume_confirm_ratio": 2.5,
      "volume_min_profit_pct": 1.0
    },
    "trailing_stop": {
      "enabled": false,
      "atr_multiplier": 1.5,
      "activation_atr": 1.0
    },
    "pump_guard": {
      "enabled": true,
      "reversal_pct": 0.5,
      "profit_lock_pct": 2.0,
      "max_staleness_sec": 60,
      "fallback_on_error": "skip"
    },
    "emergency": {
      "enabled": true,
      "max_loss_atr": 3.0,
      "max_loss_pct": 3.0,
      "max_hold_candles": 25,
      "protect_matching_trend": true
    },
    "regime_adaptation": {
      "enabled": false,
      "TRENDING": {
        "weakening_threshold": 0.4,
        "trailing_drawdown": 0.5,
        "impulse_min_profit": 2.0
      },
      "RANGING": {
        "weakening_threshold": 0.6,
        "trailing_drawdown": 0.35,
        "impulse_min_profit": 0.8
      },
      "VOLATILE": {
        "weakening_threshold": 0.55,
        "trailing_drawdown": 0.3,
        "impulse_min_profit": 1.0
      },
      "TRANSITIONAL": {
        "weakening_threshold": 0.5,
        "trailing_drawdown": 0.4,
        "impulse_min_profit": 1.5
      }
    },
    "standard_exits": {
      "enabled": false,
      "rsi_overbought": 80,
      "rsi_oversold": 20,
      "macd_reversal_profit": 0.5,
      "macd_reversal_loss": -1.0
    }
  }
}
