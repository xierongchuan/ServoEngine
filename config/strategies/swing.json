{
  "_description": "SWING - Multi-day holding with wide stops, ignoring short-term noise",
  "_version": "1.0.0",

  "preset": {
    "timeframe": "1h",
    "chart_period": "30D",
    "plotter_period": "14D",
    "loop_interval": 14400,
    "position_check_interval": 3600,
    "atr_sl_mult": 3,
    "atr_tp_mult": 6,
    "leverage": 5,
    "min_hold_hours": 24,
    "cooldown_after_close_hours": 6
  },

  "signal_rules": {
    "min_score_for_signal": 5,
    "tier1_required": true,
    "min_volume_ratio": 0.3,
    "min_atr_ratio": 0.4,

    "rsi_long_max": 55,
    "rsi_long_min": 25,
    "rsi_short_max": 75,
    "rsi_short_min": 45,
    "sr_proximity_pct": 5,

    "weights": {
      "ema_cross": 2,
      "rsi_zone": 2,
      "sr": 3,
      "volume": 1,
      "momentum": 1,
      "macd": 2
    }
  },

  "ai_filter": {
    "enabled": true,
    "can_generate_signals": true,
    "min_confidence_to_approve": 0.6,
    "auto_approve_quality": 0.8
  }
}
